# Copy this to .env for local development. Do NOT commit secrets.

# Flask
FLASK_APP=application
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# PostgreSQL for local Flask + Docker database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=book_review
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/book_review

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Full Docker note:
# If you run the web app inside Docker, change DB_HOST to db and use:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/book_review
